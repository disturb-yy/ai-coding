{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "depth": {
      "type": "string",
      "enum": ["fast", "normal", "deep"],
      "default": "normal"
    },
    "ask_clarification": {
      "type": "boolean",
      "default": true
    },
    "output_style": {
      "type": "string",
      "enum": ["strict", "flexible"],
      "default": "strict"
    }
  },
  "required": ["depth"]
}
