{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["generate", "fix", "update"],
      "default": "generate"
    },
    "run_tests": {
      "type": "boolean",
      "default": true
    },
    "coverage_target": {
      "type": "string",
      "enum": ["basic", "normal", "edge"],
      "default": "normal"
    }
  },
  "required": ["mode"]
}
