{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "depth": {
      "type": "string",
      "enum": ["fast", "normal", "deep"],
      "default": "normal"
    },
    "allow_source_fallback": {
      "type": "boolean",
      "default": true
    },
    "max_files": {
      "type": "integer",
      "minimum": 0,
      "maximum": 20,
      "default": 8
    }
  },
  "required": ["depth"]
}
