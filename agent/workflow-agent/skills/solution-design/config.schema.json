{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "depth": {
      "type": "string",
      "enum": ["fast", "normal", "deep"],
      "default": "normal"
    },
    "include_risks": {
      "type": "boolean",
      "default": true
    },
    "prefer_minimal_changes": {
      "type": "boolean",
      "default": true
    }
  },
  "required": ["depth"]
}
